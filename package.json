{
  "name": "ctrl-f-plus-chrome-extension-website",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev --webpack",
    "dev:clear-cache": "rm -rf .next && next dev --webpack",
    "build": "tsx scripts/generate-og-images.tsx && next build --webpack",
    "start": "next start",
    "lint": "next lint",
    "codemod:readonly-props": "npx jscodeshift --parser tsx --extensions tsx --transform scripts/readonly-props-codemod.ts src/app/ mdx-components.tsx",
    "codemod:readonly-props:dry": "npx jscodeshift --parser tsx --extensions tsx --transform scripts/readonly-props-codemod.ts --dry --print src/app/ mdx-components.tsx"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.1",
    "@sentry/browser": "^10.46.0",
    "atropos": "^2.0.2",
    "aws-rum-web": "^2.0.0",
    "clsx": "^2.0.0",
    "cva": "1.0.0-beta.1",
    "fastdom": "^1.0.11",
    "framer-motion": "^12.38.0",
    "gray-matter": "^4.0.3",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-player": "^2.12.0",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.0.0",
    "rehype-clipboard-prep-code": "^1.0.0",
    "rehype-pretty-code": "^0.9.5",
    "rehype-slug": "^6.0.0",
    "remark-flexible-code-titles": "^1.1.3",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "unist-util-visit": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@fontsource/inter": "^5.2.8",
    "@next/bundle-analyzer": "^16.2.1",
    "@next/env": "^16.2.1",
    "@tailwindcss/typography": "^0.5.10",
    "@types/jscodeshift": "^17.3.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "22.19.15",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.4.15",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.1",
    "eslint-config-prettier": "^10.1.8",
    "jscodeshift": "^17.3.0",
    "postcss": "8.4.31",
    "prettier": "^3.0.3",
    "prettier-plugin-tailwindcss": "^0.5.4",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
    "shiki": "^0.14.4",
    "tailwind-merge": "^1.14.0",
    "tailwindcss": "3.3.3",
    "tailwindcss-debug-screens": "^2.2.1",
    "tsx": "^4.21.0",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.57.2"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10.0.0"
  },
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/ctrl-f-plus-chrome-extension"
  }
}
